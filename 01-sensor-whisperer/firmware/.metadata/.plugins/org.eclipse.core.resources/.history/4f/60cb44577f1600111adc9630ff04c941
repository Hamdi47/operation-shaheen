#include "stm32f411xx.h"

void SystemClock_Config(void){
    /* 1. Set Flash wait states BEFORE raising clock */
    FLASH->ACR = (3UL << FLASH_ACR_LATENCY_Pos)
               | FLASH_ACR_PRFTEN
               | FLASH_ACR_ICEN
               | FLASH_ACR_DCEN;

    /* 2. Enable HSE and wait */
    RCC->CR |= RCC_CR_HSEON;
    while (!(RCC->CR & RCC_CR_HSERDY));

    /* 3. Set AHB, APB1, APB2 prescalers */
    RCC->CFGR = RCC_CFGR_HPRE_DIV1
              | RCC_CFGR_PPRE1_DIV2
              | RCC_CFGR_PPRE2_DIV1;

    /* 4. Configure PLL: HSE=25MHz → SYSCLK=100MHz */
    RCC->PLLCFGR = (25UL  <<  0)          /* PLLM = 25  */
                 | (400UL <<  6)          /* PLLN = 400 */
                 | (1UL   << 16)          /* PLLP = /4  */
                 | RCC_PLLCFGR_PLLSRC_HSE
                 | (8UL   << 24);         /* PLLQ = 8   */

    /* 5. Enable PLL and wait */
    RCC->CR |= RCC_CR_PLLON;
    while (!(RCC->CR & RCC_CR_PLLRDY));

    /* 6. Switch system clock to PLL */
    RCC->CFGR |= RCC_CFGR_SW_PLL;
    while ((RCC->CFGR & RCC_CFGR_SWS_Msk) != RCC_CFGR_SWS_PLL);

}

void GPIO_Init(void){
    /* Enable GPIOC clock */
    RCC->AHB1ENR |= RCC_AHB1ENR_GPIOCEN;
    (void)RCC->AHB1ENR;  /* short delay for clock to settle */

    /* PC13 as output */
    GPIOC->MODER &= ~GPIO_MODER_PC13_Msk;
    GPIOC->MODER |=  (GPIO_MODE_OUTPUT << GPIO_MODER_PC13_Pos);

    /* LED off initially (active LOW, so set HIGH) */
    GPIOC->BSRR = GPIO_BSRR_BS13;

}

void TIM2_Init(void){
    /* Enable TIM2 clock */
    RCC->APB1ENR |= RCC_APB1ENR_TIM2EN;
    (void)RCC->APB1ENR;

    TIM2->CR1  = 0;
    TIM2->PSC  = 10000 - 1;   /* 100MHz / 10000 = 10kHz */
    TIM2->ARR  = 10000 - 1;   /* 10kHz  / 10000 = 1Hz   */
    TIM2->CR1 |= TIM_CR1_ARPE;
    TIM2->EGR  = TIM_EGR_UG;  /* load PSC and ARR now   */
    TIM2->SR  &= ~TIM_SR_UIF;  /* clear the flag it set  */
    TIM2->DIER |= TIM_DIER_UIE;

    NVIC_SetPriority(TIM2_IRQn, 1);
    NVIC_EnableIRQ(TIM2_IRQn);

    TIM2->CR1 |= TIM_CR1_CEN;  /* start counter */

}

void TIM2_IRQHandler(void){
    if (TIM2->SR & TIM_SR_UIF)
    {
        TIM2->SR &= ~TIM_SR_UIF;      /* clear flag first */
        GPIOC->ODR ^= GPIO_ODR_OD13;  /* toggle LED       */
    }

}

int main(void){
	SystemClock_Config();
	GPIO_Init();
	TIM2_Init();

	while (1){}

}
